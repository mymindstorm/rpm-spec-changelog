{
	"name": "rpmspec-changelog",
	"displayName": "RPM Spec Changelog",
	"description": "Inserts a properly formatted changelog line to your RPM spec file for you.",
	"version": "1.1.0",
	"publisher": "Adadov",
  "license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/Adadov/rpmspec-changelog.git"
	},
	"bugs": {
		"url": "https://github.com/Adadov/rpmspec-changelog/issues"
	},
	"engines": {
		"vscode": "^1.82.0"
	},
	"categories": [
		"Snippets",
		"Other"
	],
	"main": "./out/extension.js",
	"contributes": {
		"commands": [
			{
				"command": "extension.insertRPMSpecChangelog",
				"title": "RPM: Insert Changelog"
			}
		]
	},
	"scripts": {
		"vscode:prepublish": "npm run compile",
		"compile": "tsc -p ./",
		"lint": "eslint src --ext ts",
		"watch": "tsc -watch -p ./",
		"pretest": "npm run compile && npm run lint"
	},
	"devDependencies": {
		"@types/glob": "^7.1.1",
		"@types/node": "^12.11.7",
		"@types/vscode": "^1.82.0",
		"@typescript-eslint/eslint-plugin": "^2.18.0",
		"@typescript-eslint/parser": "^2.18.0",
		"eslint": "^6.8.0",
		"glob": "^7.1.6",
		"typescript": "^5.2.2",
		"vscode-test": "^1.3.0"
	}
}
